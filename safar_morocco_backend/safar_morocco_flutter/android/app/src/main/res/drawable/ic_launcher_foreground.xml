        android:translateY="54">
        
        <!-- Outer compass ring (white ring) -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.1"
            android:pathData="M0,-25 A25,25 0,1 1,0,25 A25,25 0,1 1,0,-25 Z"/>
        
        <!-- Inner compass ring (darker ring) -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.05"
            android:pathData="M0,-18 A18,18 0,1 1,0,18 A18,18 0,1 1,0,-18 Z"/>
        
        <!-- Cardinal direction markers -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,-25 L3,-20 L0,-22 L-3,-20 Z"/>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,25 L-3,20 L0,22 L3,20 Z"/>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M-25,0 L-20,3 L-22,0 L-20,-3 Z"/>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M25,0 L20,-3 L22,0 L20,3 Z"/>
        
        <!-- North needle (red and white) -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,-20 L5,-8 L0,0 L-5,-8 Z"/>
        <path
            android:fillColor="#DC2626"
            android:pathData="M0,-20 L3,-10 L0,0 L-3,-10 Z"/>
        
        <!-- South needle (dark) -->
        <path
            android:fillColor="#374151"
            android:pathData="M0,20 L-5,8 L0,0 L5,8 Z"/>
        
        <!-- East needle -->
        <path
            android:fillColor="#6B7280"
            android:pathData="M20,0 L8,-5 L0,0 L8,5 Z"/>
        
        <!-- West needle -->
        <path
            android:fillColor="#6B7280"
            android:pathData="M-20,0 L-8,5 L0,0 L-8,-5 Z"/>
        
        <!-- Center circle -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,0 m-3,0a3,3 0,1 1,6,0a3,3 0,1 1,-6,0"/>
        <path
            android:fillColor="#1E40AF"
            android:pathData="M0,0 m-1.5,0a1.5,1.5 0,1 1,3,0a1.5,1.5 0,1 1,-3,0"/>
        
        <!-- Direction letters -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,-30 L-1,-28 L1,-28 Z M-1,-29 L1,-29"/>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,30 L-1,28 L1,28 Z"/>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M-30,0 L-28,-1 L-28,1 Z"/>
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M30,0 L28,-1 L28,1 Z"/>
